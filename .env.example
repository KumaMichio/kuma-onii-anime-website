# Copy this file to .env and fill in the values before running docker compose

# Secret key for JWT tokens — change this!
JWT_SECRET=your_strong_secret_here

# Frontend origin allowed by the backend CORS policy
FRONTEND_URL=http://localhost:3000

# Baked into the Next.js bundle at build time — must point to where the backend is reachable FROM THE BROWSER
NEXT_PUBLIC_API_URL=http://localhost:3001
